# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://admin:@localhost:5432/skillcoin

# ─── Lighthouse / Filecoin ──────────────────────────────
LIGHTHOUSE_API_KEY=your_lighthouse_api_key

# ─── Synapse SDK ────────────────────────────────────────
SYNAPSE_PRIVATE_KEY=0x...
SYNAPSE_NETWORK=calibration

# ─── x402 Payment ──────────────────────────────────────
ADMIN_VAULT_ADDRESS=0xYourAdminVaultAddress
X402_PAYMENT_AMOUNT=0.5
X402_PAYMENT_CURRENCY=USDC
PAYMENT_VERIFY_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-key

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRY=1h

# ─── Flow (optional) ───────────────────────────────────
FLOW_NETWORK=testnet
FLOW_CONTRACT_ADDRESS=0x...
FLOW_PRIVATE_KEY=...

# ─── App ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
