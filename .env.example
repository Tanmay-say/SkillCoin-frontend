# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/skillcoin
DIRECT_URL=postgresql://postgres:password@localhost:5432/skillcoin

# ─── Filecoin Pin / Synapse SDK (replaces Lighthouse) ───
FILECOIN_PRIVATE_KEY=               # wallet private key for Filecoin Calibration + Base Sepolia
FILECOIN_WALLET_ADDRESS=            # corresponding public address
FILECOIN_NETWORK=calibration        # "calibration" for testnet, "mainnet" for prod
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# ─── Deployed Contract Addresses ────────────────────────
SKILL_REGISTRY_ADDRESS=0x30AcdeB5C03F5E02b0E7e9f22B20cBC4dF182690
SKILL_LICENSE_NFT_ADDRESS=0x7cFaf07016514f5261768Ce991D9E373cBC8d6e9

# ─── ERC-8004 Agent Registry (Base Sepolia) ─────────────
AGENT_REGISTRY_ADDRESS=0x8004AA63c570c570eBF15376c0dB199918BFe9Fb
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── Gemini AI (for skill generation) ───────────────────
GEMINI_API_KEY=                     # Google AI Studio: https://aistudio.google.com/apikey

# ─── x402 Payment ──────────────────────────────────────
ADMIN_VAULT_ADDRESS=0xYourAdminVaultAddress
X402_PAYMENT_AMOUNT=0.5
X402_PAYMENT_CURRENCY=USDC
PAYMENT_VERIFY_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRY=24h

# ─── App ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
