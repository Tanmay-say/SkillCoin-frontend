# ─── Database (Supabase PostgreSQL) ────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ─── Lighthouse / Filecoin ──────────────────────────────
LIGHTHOUSE_API_KEY=your_lighthouse_api_key

# ─── Synapse SDK ────────────────────────────────────────
SYNAPSE_PRIVATE_KEY=0x...
SYNAPSE_NETWORK=calibration

# ─── x402 Payment ──────────────────────────────────────
ADMIN_VAULT_ADDRESS=0xYourAdminVaultAddress
X402_PAYMENT_AMOUNT=0.5
X402_PAYMENT_CURRENCY=USDC
PAYMENT_VERIFY_RPC_URL=https://api.calibration.node.glif.io

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=skillcoin-jwt-secret-change-this-in-prod
JWT_EXPIRY=24h

# ─── App ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
