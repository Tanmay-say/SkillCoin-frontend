# ─── Database (Supabase PostgreSQL) ────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ─── Filecoin Pin / Synapse SDK ──────────────────────
FILECOIN_PRIVATE_KEY=0x...your_filecoin_calibration_private_key
FILECOIN_WALLET_ADDRESS=0x...your_wallet_address
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_NETWORK=calibration

# ─── Deployed Contract Addresses (Filecoin Calibration FVM) ─
SKILL_REGISTRY_ADDRESS=0x30AcdeB5C03F5E02b0E7e9f22B20cBC4dF182690
SKILL_LICENSE_NFT_ADDRESS=0x7cFaf07016514f5261768Ce991D9E373cBC8d6e9

# ─── ERC-8004 Agent Registry (Base Sepolia) ──────────
AGENT_REGISTRY_ADDRESS=0x8004AA63c570c570eBF15376c0dB199918BFe9Fb
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── Gemini AI (for skill generation) ────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── x402 Payment ──────────────────────────────────
ADMIN_VAULT_ADDRESS=0xYourAdminVaultAddress
X402_PAYMENT_AMOUNT=0.5
X402_PAYMENT_CURRENCY=USDC
PAYMENT_VERIFY_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# ─── Auth ───────────────────────────────────────────
JWT_SECRET=skillcoin-jwt-secret-change-this-in-prod-min-32-chars
JWT_EXPIRY=24h

# ─── App ────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
