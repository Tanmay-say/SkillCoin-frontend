# ─── SkillCoin Web App — Vercel Environment Variables ───────────────────────
# Copy these into Vercel Dashboard → Settings → Environment Variables

# REQUIRED: URL of your deployed API server (Railway / Render / Fly.io)
# Example: https://skillcoin-api.up.railway.app
NEXT_PUBLIC_API_URL=https://your-api-url.railway.app

# OPTIONAL: JWT secret (only needed if the web app verifies tokens itself)
# JWT_SECRET=your_jwt_secret_at_least_32_characters_long
