{
  "name": "skillcoin",
  "version": "0.5.0",
  "description": "npm for AI Agent Skills — Decentralized, Paid, Permanent. Install AI skills from the Skillcoin marketplace stored on Filecoin/IPFS.",
  "bin": {
    "skillcoin": "./dist/bin/skillcoin.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "start": "node dist/bin/skillcoin.js"
  },
  "keywords": [
    "ai",
    "skills",
    "filecoin",
    "cli",
    "agents",
    "ipfs",
    "filecoin-pin",
    "synapse",
    "marketplace",
    "npm"
  ],
  "author": "Tanmay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tanmay-say/skillcoin-frontend"
  },
  "homepage": "https://github.com/Tanmay-say/skillcoin-frontend#readme",
  "bugs": "https://github.com/Tanmay-say/skillcoin-frontend/issues",
  "dependencies": {
    "@filoz/synapse-sdk": "^0.1.0",
    "@google/generative-ai": "^0.21.0",
    "adm-zip": "^0.4.16",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ethers": "^6.12.0",
    "filecoin-pin": "^0.18.0",
    "open": "^8.4.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
